{% doc %}
  @prompt
    Create a section to showcase the team images with names and designations
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-team-showcase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
  }

  .ai-team-showcase__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-team-showcase__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-team-showcase__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
  }

  .ai-team-showcase__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-team-showcase__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-team-showcase__member-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-team-showcase__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    margin-bottom: 16px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-team-showcase__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-team-showcase__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-team-showcase__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-team-showcase__name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    color: {{ block.settings.name_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-team-showcase__designation-{{ ai_gen_id }} {
    font-size: {{ block.settings.designation_size }}px;
    color: {{ block.settings.designation_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-team-showcase__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-team-showcase__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-team-showcase__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<team-showcase-{{ ai_gen_id }} class="ai-team-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-team-showcase__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-team-showcase__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-team-showcase__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-team-showcase__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-team-showcase__grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign member_enabled_key = 'member_' | append: i | append: '_enabled'
          assign member_image_key = 'member_' | append: i | append: '_image'
          assign member_name_key = 'member_' | append: i | append: '_name'
          assign member_designation_key = 'member_' | append: i | append: '_designation'

          assign member_enabled = block.settings[member_enabled_key]
          assign member_image = block.settings[member_image_key]
          assign member_name = block.settings[member_name_key]
          assign member_designation = block.settings[member_designation_key]
        %}

        {% if member_enabled %}
          <div class="ai-team-showcase__member-{{ ai_gen_id }}">
            <div class="ai-team-showcase__image-wrapper-{{ ai_gen_id }}">
              {% if member_image %}
                <img
                  src="{{ member_image | image_url: width: 600 }}"
                  alt="{{ member_name | escape }}"
                  loading="lazy"
                  width="600"
                  height="600"
                  class="ai-team-showcase__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-team-showcase__image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            {% if member_name != blank %}
              <h3 class="ai-team-showcase__name-{{ ai_gen_id }}">{{ member_name }}</h3>
            {% endif %}
            {% if member_designation != blank %}
              <p class="ai-team-showcase__designation-{{ ai_gen_id }}">{{ member_designation }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</team-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class TeamShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('team-showcase-{{ ai_gen_id }}', TeamShowcase{{ ai_gen_id }});
  })();
</script>

