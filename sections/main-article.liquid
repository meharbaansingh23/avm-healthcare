{{ 'blog-styles.css' | asset_url | stylesheet_tag }}

<article class="avm-article">

  {%- for block in section.blocks -%}
    {%- case block.type -%}

      {%- when '@app' -%}
        <div class="avm-article__container">
          {% render block %}
        </div>

      {%- when 'featured_image' -%}
        {%- if article.image -%}
          <div class="avm-article__hero" {{ block.shopify_attributes }}>
            <img
              srcset="
                {% if article.image.width >= 760 %}{{ article.image | image_url: width: 760 }} 760w,{% endif %}
                {% if article.image.width >= 1200 %}{{ article.image | image_url: width: 1200 }} 1200w,{% endif %}
                {% if article.image.width >= 1920 %}{{ article.image | image_url: width: 1920 }} 1920w,{% endif %}
                {{ article.image | image_url }} {{ article.image.width }}w
              "
              sizes="(min-width: 960px) 920px, 100vw"
              src="{{ article.image | image_url: width: 1200 }}"
              alt="{{ article.image.alt | default: article.title | escape }}"
              loading="eager"
              fetchpriority="high"
              width="{{ article.image.width }}"
              height="{{ article.image.height }}"
            >
          </div>
        {%- endif -%}

      {%- when 'title' -%}
        <div class="avm-article__container" {{ block.shopify_attributes }}>
          <a href="/blogs/avm-insights" class="avm-article__back">
            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to AVM Insights
          </a>
          <div class="avm-article__meta">
            {%- if article.tags.size > 0 -%}
              <span class="avm-article__tag">{{ article.tags.first }}</span>
            {%- endif -%}
            <h1 class="avm-article__title">{{ article.title | escape }}</h1>
            <div class="avm-article__byline">
              {%- if block.settings.blog_show_date -%}
                <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{ article.published_at | date: "%B %d, %Y" }}
                </time>
              {%- endif -%}
              {%- if block.settings.blog_show_author -%}
                <span>{{ article.author }}</span>
              {%- endif -%}
            </div>
          </div>
          <hr class="avm-article__divider">
        </div>

      {%- when 'content' -%}
        <div class="avm-article__container" {{ block.shopify_attributes }}>
          <div class="avm-article__content rte">
            {{ article.content }}
          </div>
          <div class="avm-article__footer">
            <a href="/blogs/avm-insights" class="avm-article__back">
              <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Back to AVM Insights
            </a>
          </div>
        </div>

      {%- when 'share' -%}
        <div class="avm-article__container" {{ block.shopify_attributes }}>
          {% assign share_url = request.origin | append: article.url %}
          {% render 'share-button', block: block, share_link: share_url %}
        </div>

    {%- endcase -%}
  {%- endfor -%}

</article>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% schema %}
{
  "name": "Blog article",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "featured_image",
      "name": "Featured image",
      "limit": 1,
      "settings": []
    },
    {
      "type": "title",
      "name": "Title & date",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "blog_show_date",
          "default": true,
          "label": "Show date"
        },
        {
          "type": "checkbox",
          "id": "blog_show_author",
          "default": false,
          "label": "Show author"
        }
      ]
    },
    {
      "type": "content",
      "name": "Content",
      "limit": 1
    },
    {
      "type": "share",
      "name": "Share",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "share_label",
          "label": "Share label",
          "default": "Share"
        }
      ]
    }
  ]
}
{% endschema %}
