<style>
  .avm-values {
    background: #fff;
    padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px;
  }

  .avm-values__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .avm-values__heading {
    font-size: 32px;
    font-weight: 700;
    color: #0f1f3d;
    margin: 0;
    letter-spacing: -0.3px;
  }

  .avm-values__grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .avm-values__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .avm-values__icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #EEF4FF;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .avm-values__title {
    font-size: 17px;
    font-weight: 600;
    color: #0f1f3d;
    margin: 0 0 10px;
  }

  .avm-values__text {
    font-size: 15px;
    color: #4b5563;
    line-height: 1.7;
    margin: 0;
  }

  @media screen and (max-width: 899px) {
    .avm-values__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 599px) {
    .avm-values {
      padding-left: 24px;
      padding-right: 24px;
    }
    .avm-values__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>

<div class="avm-values">
  <div class="avm-values__header">
    <h2 class="avm-values__heading">Our Values</h2>
  </div>

  <div class="avm-values__grid">

    <div class="avm-values__item">
      <div class="avm-values__icon-wrap">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1a5fa8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
      </div>
      <h3 class="avm-values__title">Quality Assured</h3>
      <p class="avm-values__text">Certified products from trusted global manufacturers, meeting international healthcare standards.</p>
    </div>

    <div class="avm-values__item">
      <div class="avm-values__icon-wrap">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1a5fa8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      </div>
      <h3 class="avm-values__title">Global Presence</h3>
      <p class="avm-values__text">Operations in India, Germany, Taiwan, and Dubai, serving clients across multiple continents.</p>
    </div>

    <div class="avm-values__item">
      <div class="avm-values__icon-wrap">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1a5fa8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
      </div>
      <h3 class="avm-values__title">Innovation Driven</h3>
      <p class="avm-values__text">Continuously evolving product range to meet the dynamic needs of modern healthcare.</p>
    </div>

    <div class="avm-values__item">
      <div class="avm-values__icon-wrap">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1a5fa8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </div>
      <h3 class="avm-values__title">Customer Commitment</h3>
      <p class="avm-values__text">Building lasting relationships through tailored solutions and responsive service.</p>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Our Values",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Our Values"
    }
  ]
}
{% endschema %}
