{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<style>
  /* ================================================
     AVM Custom Footer — #0f1f3d deep navy
     ================================================ */

  .avm-footer-wrapper {
    background: #0f1f3d;
    font-family: 'Google Sans Flex', sans-serif;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .avm-footer-wrapper {
      margin-top: {{ section.settings.margin_top }}px;
    }
  }

  .avm-footer-wrapper * {
    font-family: 'Google Sans Flex', sans-serif;
    box-sizing: border-box;
  }

  .avm-footer {
    background: #0f1f3d;
    color: #e5e7eb;
    padding: 64px 0 0;
  }

  .avm-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 56px;
  }

  @media screen and (max-width: 899px) {
    .avm-footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 36px;
    }
  }

  @media screen and (max-width: 599px) {
    .avm-footer__inner {
      grid-template-columns: 1fr;
      padding: 0 24px;
      gap: 32px;
    }
  }

  /* Column heading */
  .avm-footer__col-heading {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: #93c5fd;
    margin: 0 0 18px;
  }

  /* ---- Left column ---- */
  .avm-footer__logo-link {
    display: inline-block;
    margin-bottom: 16px;
    text-decoration: none;
  }

  .avm-footer__logo-img {
    max-height: 40px;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
  }

  .avm-footer__logo-name {
    font-size: 20px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.3px;
  }

  .avm-footer__tagline {
    font-size: 14px;
    color: #9ca3af;
    line-height: 1.65;
    margin: 0 0 24px;
    max-width: 280px;
  }

  .avm-footer__copy {
    font-size: 12px;
    color: #6b7280;
    margin: 0;
  }

  /* ---- Quick links ---- */
  .avm-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .avm-footer__links li {
    margin-bottom: 11px;
  }

  .avm-footer__links a {
    font-size: 14px;
    color: #d1d5db;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .avm-footer__links a:hover {
    color: #fff;
  }

  /* ---- Contact ---- */
  .avm-footer__contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .avm-footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 16px;
  }

  .avm-footer__contact-icon {
    display: flex;
    align-items: flex-start;
    flex-shrink: 0;
    margin-top: 2px;
    color: #93c5fd;
    width: 16px;
    height: 16px;
  }

  .avm-footer__contact-icon svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .avm-footer__contact-text {
    font-size: 14px;
    color: #e5e7eb;
    line-height: 1.6;
    margin: 0;
  }

  .avm-footer__contact-text a {
    color: #e5e7eb;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .avm-footer__contact-text a:hover {
    color: #fff;
  }

  /* ---- Bottom bar ---- */
  .avm-footer__bottom-outer {
    background: #0f1f3d;
    margin-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 24px;
  }

  .avm-footer__bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  @media screen and (max-width: 599px) {
    .avm-footer__bottom {
      padding: 0 24px 28px;
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .avm-footer__bottom-note {
    font-size: 13px;
    color: #9ca3af;
    margin: 0;
  }

  .avm-footer__policies {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .avm-footer__policies a {
    font-size: 13px;
    color: #9ca3af;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .avm-footer__policies a:hover {
    color: #e5e7eb;
  }

  /* Hide Dawn's "Powered by Shopify" */
  .avm-footer-wrapper .powered-by-link,
  .avm-footer-wrapper [data-shopify="powered_by_shopify"],
  .powered-by-shopify {
    display: none !important;
  }
</style>

<div class="avm-footer-wrapper">
  <footer class="avm-footer">

    <div class="avm-footer__inner">

      <!-- Left column: Logo + Tagline + Copyright -->
      <div class="avm-footer__col">
        <a href="{{ routes.root_url }}" class="avm-footer__logo-link">
          {%- if settings.logo != blank -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            <img
              src="{{ settings.logo | image_url: width: 280 }}"
              alt="{{ settings.logo.alt | default: shop.name | escape }}"
              loading="lazy"
              class="avm-footer__logo-img"
              width="{{ settings.logo_width }}"
              height="{{ logo_height }}"
            >
          {%- else -%}
            <span class="avm-footer__logo-name">{{ shop.name }}</span>
          {%- endif -%}
        </a>
        <p class="avm-footer__tagline">Precision instruments for modern healthcare.</p>
        <p class="avm-footer__copy">&copy; {{ 'now' | date: '%Y' }} AVM Healthcare Pvt. Ltd.</p>
      </div>

      <!-- Middle column: Quick Links -->
      <div class="avm-footer__col">
        <p class="avm-footer__col-heading">Quick Links</p>
        <ul class="avm-footer__links">
          <li><a href="/">Home</a></li>
          <li><a href="/collections">Categories</a></li>
          <li><a href="/pages/catalog">Catalog</a></li>
          <li><a href="/pages/about-us">About Us</a></li>
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="/blogs/avm-insights">Insights</a></li>
        </ul>
      </div>

      <!-- Right column: Contact -->
      <div class="avm-footer__col">
        <p class="avm-footer__col-heading">Contact</p>
        <ul class="avm-footer__contact-list">
          <li class="avm-footer__contact-item">
            <span class="avm-footer__contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            </span>
            <p class="avm-footer__contact-text">17-19 A Block Chattarpur Extension,<br>Rajpur Road, New Delhi – 110074</p>
          </li>
          <li class="avm-footer__contact-item">
            <span class="avm-footer__contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </span>
            <p class="avm-footer__contact-text">
              <a href="mailto:info@avmhealthcare.com">info@avmhealthcare.com</a>
            </p>
          </li>
          <li class="avm-footer__contact-item">
            <span class="avm-footer__contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </span>
            <p class="avm-footer__contact-text">+91 99585 38469</p>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="avm-footer__bottom-outer">
      <div class="avm-footer__bottom">
        <p class="avm-footer__bottom-note">&copy; {{ 'now' | date: '%Y' }} AVM Healthcare Pvt. Ltd. All rights reserved.</p>
        <ul class="avm-footer__policies">
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <li><a href="{{ policy.url }}">{{ policy.title | escape }}</a></li>
            {%- endif -%}
          {%- endfor -%}
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
        </ul>
      </div>
    </div>

  </footer>
</div>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "Show policy links"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 0
    }
  ],
  "default": {
    "settings": {}
  }
}
{% endschema %}
