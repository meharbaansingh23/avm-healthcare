{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<style>
  /* ================================================
     AVM Custom Footer — #0f1f3d deep navy
     ================================================ */

  .avm-footer-wrapper {
    background: #0f1f3d;
    font-family: 'Google Sans Flex', sans-serif;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .avm-footer-wrapper {
      margin-top: {{ section.settings.margin_top }}px;
    }
  }

  .avm-footer-wrapper * {
    font-family: 'Google Sans Flex', sans-serif;
    box-sizing: border-box;
  }

  .avm-footer {
    background: #0f1f3d;
    color: #e5e7eb;
    padding: 64px 0 0;
  }

  .avm-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 56px;
  }

  @media screen and (max-width: 899px) {
    .avm-footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 36px;
    }
  }

  @media screen and (max-width: 599px) {
    .avm-footer__inner {
      grid-template-columns: 1fr;
      padding: 0 24px;
      gap: 32px;
    }
  }

  /* Column heading */
  .avm-footer__col-heading {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: #93c5fd;
    margin: 0 0 18px;
  }

  /* ---- Left column ---- */
  .avm-footer__logo-link {
    display: inline-block;
    margin-bottom: 16px;
    text-decoration: none;
  }

  .avm-footer__logo-img {
    max-height: 40px;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
  }

  .avm-footer__logo-name {
    font-size: 20px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.3px;
  }

  .avm-footer__tagline {
    font-size: 14px;
    color: #9ca3af;
    line-height: 1.65;
    margin: 0 0 24px;
    max-width: 280px;
  }

  .avm-footer__copy {
    font-size: 12px;
    color: #6b7280;
    margin: 0;
  }

  /* ---- Quick links ---- */
  .avm-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .avm-footer__links li {
    margin-bottom: 11px;
  }

  .avm-footer__links a {
    font-size: 14px;
    color: #d1d5db;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .avm-footer__links a:hover {
    color: #fff;
  }

  /* ---- Contact ---- */
  .avm-footer__contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .avm-footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 16px;
  }

  .avm-footer__contact-icon {
    font-style: normal;
    font-size: 13px;
    flex-shrink: 0;
    line-height: 1.6;
    width: 18px;
    text-align: center;
    color: #93c5fd;
  }

  .avm-footer__contact-text {
    font-size: 14px;
    color: #d1d5db;
    line-height: 1.6;
    margin: 0;
  }

  .avm-footer__contact-text a {
    color: #d1d5db;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .avm-footer__contact-text a:hover {
    color: #fff;
  }

  /* ---- Bottom bar ---- */
  .avm-footer__bottom-outer {
    background: #0f1f3d;
    margin-top: 48px;
    border-top: 1px solid #1e3460;
  }

  .avm-footer__bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  @media screen and (max-width: 599px) {
    .avm-footer__bottom {
      padding: 20px 24px;
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .avm-footer__bottom-note {
    font-size: 12px;
    color: #6b7280;
    margin: 0;
  }

  .avm-footer__policies {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .avm-footer__policies a {
    font-size: 12px;
    color: #6b7280;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .avm-footer__policies a:hover {
    color: #d1d5db;
  }

  /* Hide Dawn's "Powered by Shopify" */
  .avm-footer-wrapper .powered-by-link,
  .avm-footer-wrapper [data-shopify="powered_by_shopify"],
  .powered-by-shopify {
    display: none !important;
  }
</style>

<div class="avm-footer-wrapper">
  <footer class="avm-footer">

    <div class="avm-footer__inner">

      <!-- Left column: Logo + Tagline + Copyright -->
      <div class="avm-footer__col">
        <a href="{{ routes.root_url }}" class="avm-footer__logo-link">
          {%- if settings.logo != blank -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            <img
              src="{{ settings.logo | image_url: width: 280 }}"
              alt="{{ settings.logo.alt | default: shop.name | escape }}"
              loading="lazy"
              class="avm-footer__logo-img"
              width="{{ settings.logo_width }}"
              height="{{ logo_height }}"
            >
          {%- else -%}
            <span class="avm-footer__logo-name">{{ shop.name }}</span>
          {%- endif -%}
        </a>
        <p class="avm-footer__tagline">Precision instruments for modern healthcare.</p>
        <p class="avm-footer__copy">&copy; {{ 'now' | date: '%Y' }} AVM Healthcare Pvt. Ltd.</p>
      </div>

      <!-- Middle column: Quick Links -->
      <div class="avm-footer__col">
        <p class="avm-footer__col-heading">Quick Links</p>
        <ul class="avm-footer__links">
          <li><a href="/">Home</a></li>
          <li><a href="/collections">Categories</a></li>
          <li><a href="/pages/catalog">Catalog</a></li>
          <li><a href="/pages/about-us">About Us</a></li>
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="/blogs/avm-insights">Insights</a></li>
        </ul>
      </div>

      <!-- Right column: Contact -->
      <div class="avm-footer__col">
        <p class="avm-footer__col-heading">Contact</p>
        <ul class="avm-footer__contact-list">
          <li class="avm-footer__contact-item">
            <i class="avm-footer__contact-icon">📍</i>
            <p class="avm-footer__contact-text">New Delhi, India</p>
          </li>
          <li class="avm-footer__contact-item">
            <i class="avm-footer__contact-icon">✉</i>
            <p class="avm-footer__contact-text">
              <a href="mailto:info@avmhealthcare.com">info@avmhealthcare.com</a>
            </p>
          </li>
          <li class="avm-footer__contact-item">
            <i class="avm-footer__contact-icon">📞</i>
            <p class="avm-footer__contact-text">+91 XXXXXXXXXX</p>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="avm-footer__bottom-outer">
      <div class="avm-footer__bottom">
        <p class="avm-footer__bottom-note">All rights reserved.</p>
        {%- if section.settings.show_policy -%}
          <ul class="avm-footer__policies">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <li><a href="{{ policy.url }}">{{ policy.title | escape }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>

  </footer>
</div>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "Show policy links"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 0
    }
  ],
  "default": {
    "settings": {}
  }
}
{% endschema %}
